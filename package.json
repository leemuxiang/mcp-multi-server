{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "mcp-todo": "./dist/mcp-stdio.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "start:http": "tsx server.ts",
    "start:stdio": "tsx src/mcp-server.ts --stdio",
    "build": "npm run clean && npm run build:web && npm run build:stdio && npm run build:server && npm run build:assets",
    "build:web": "vite build",
    "build:stdio": "esbuild src/mcp-server.ts --bundle --platform=node --format=esm --outfile=dist/mcp-stdio.js --banner:js=\"#!/usr/bin/env node\" && chmod +x dist/mcp-stdio.js",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --outfile=dist/mcp-server-http.js --external:vite",
    "build:assets": "cp SKILL.md dist/",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "npm run build && npm publish --registry=https://devwh.ccdc.com:8086/npm/"
  },
  "publishConfig": {
    "registry": "https://devwh.ccdc.com:8086/npm/"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.4"
  }
}
